   "source": [
    "# IDEA:\n",
    "\n",
    "# Brainstorm exactly like doing a real permutation\n",
    "# e.g: 'TWO' => first target T, then have 2 chars left: WO, we call the permutation recursively then find all permutations of WO\n",
    "# later combine the T with all the permutations\n",
    "# We repeating targetting for W and O.\n",
    "# After all, we'll get an array of all the permutations of the strings\n",
    "\n",
    "def permutate(s: str) -> list[str]: \n",
    "    return permutate_recursive(\"\", s)\n",
    "    \n",
    "\n",
    "def permutate_recursive(s1: str, s2: str) -> list[str]:\n",
    "    output = []\n",
    "    \n",
    "    # base case: if the original string has no remaining characters -> that means one full permutation is done\n",
    "    if( len(s2) == 0 ): \n",
    "        return [s1]\n",
    "    \n",
    "    for i in range( len(s2) ):\n",
    "        # target one letter\n",
    "        current_letter = s2[i]\n",
    "        \n",
    "        # then this is the string of the remaining letters\n",
    "        remaining_letters = s2[0:i] + s2[i + 1:]\n",
    "        \n",
    "        # find all permutations of the remaining letters\n",
    "        perms_of_remainingLetters = permutate_recursive(s1 + current_letter, remaining_letters)\n",
    "        \n",
    "        # Add the permutations of the remaining letters to the currently targeted letter to form permutations for the whole original string(s2)\n",
    "        for onePerm in perms_of_remainingLetters:\n",
    "            output.append(onePerm)\n",
    "        \n",
    "    return output"
   ]
