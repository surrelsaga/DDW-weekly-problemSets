    "def quicksort(array: list) -> list:\n",
    "    left_array = []\n",
    "    right_array = []\n",
    "    \n",
    "    pivot = len(array) // 2\n",
    "    \n",
    "    # base case is when the array length = 1\n",
    "    if ( len(array) == 1 or len(array) == 0 ):\n",
    "        return array\n",
    "    \n",
    "    # recursive case: we loop through each items inside the array, then compare\n",
    "    for i in range(len(array)):\n",
    "        if i != pivot:\n",
    "            if array[i] <= array[pivot]:\n",
    "                left_array.append(array[i])\n",
    "            if array[i] > array[pivot]:\n",
    "                right_array.append(array[i])\n",
    "    \n",
    "    return quicksort(left_array) + [ array[pivot] ] + quicksort(right_array)\n",
    "        "
   ]
